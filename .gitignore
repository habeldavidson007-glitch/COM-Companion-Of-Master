```gitignore
# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Logs
*.log

# Environment
.env
.env.local
*.env.*

# Dependencies
.venv/
venv/
pip-log.txt
pipenv.lock

# Coverage reports
.coverage
htmlcov/
.coverage.*
.cache

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
dist/
build/
*.egg-info/
target/

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# Original rules preserved
*.log
```