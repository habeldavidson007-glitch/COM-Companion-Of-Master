```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Logs and temporary files
*.log
*.tmp

# Environment files
.env
.env.local
*.env.*

# Editors and IDE
.vscode/
.idea/

# Coverage reports
coverage/
htmlcov/
.coverage

# Package management
node_modules/
.venv/
venv/
.mypy_cache/
.pytest_cache/

# Build directories
dist/
build/
target/

# System files
.DS_Store
Thumbs.db
```